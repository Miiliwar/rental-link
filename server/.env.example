# Safaricom Ethiopia sandbox — from developer portal (never commit real .env)
MPESA_PORT=8787

# OAuth (Generate Token in Postman)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# STK / Lipa
MPESA_BUSINESS_SHORT_CODE=6564
# Lipa passkey from portal (used with shortcode + timestamp to build Password)
MPESA_PASSKEY=

# Optional: paste exact base64 Password from Postman if generation differs for your app
# MPESA_PASSWORD_BASE64=

# Public HTTPS URL Safaricom can POST to (use webhook.site or your backend for callbacks)
MPESA_CALLBACK_URL=https://example.com/mpesa-callback
